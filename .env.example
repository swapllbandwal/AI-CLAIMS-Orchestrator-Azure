# =============================================================================
# AI-CLAIMS-Orchestrator-Azure  —  Environment configuration
# Copy this file to ".env" and fill in your keys.
# =============================================================================

# --- Azure Computer Vision ---------------------------------------------------
AZURE_CV_ENDPOINT=  
AZURE_CV_KEY=REPLACE_WITH_YOUR_CV_KEY

# --- Microsoft AI Foundry (Claude Sonnet 4.6) --------------------------------
# Endpoint is the BASE; the SDK will append /v1/messages itself.
FOUNDRY_ENDPOINT=REPLACE_WITH_YOUR_FOUNDRY_ENDPOINT
FOUNDRY_API_KEY=REPLACE_WITH_YOUR_FOUNDRY_KEY
FOUNDRY_MODEL=claude-sonnet-4-6

# --- Backend -----------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8005
DEBUG_MODE=True

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- RAG ---------------------------------------------------------------------
# Local sentence-transformer model (downloaded once on first run, ~80 MB, CPU only)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
